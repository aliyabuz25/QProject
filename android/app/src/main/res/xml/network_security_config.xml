<?xml version="1.0" encoding="utf-8"?>
<!--
    Network security config — fully allows all connections to the KidsBibleStories backend.
    Covers both HTTP and HTTPS, all backend hostnames and IPs.
-->
<network-security-config>
    <!-- Trust system CAs for all HTTPS connections (default, but explicit) -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system"/>
            <certificates src="user"/>
        </trust-anchors>
    </base-config>

    <!-- Production backend over HTTP -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">54.196.133.35</domain>
        <trust-anchors>
            <certificates src="system"/>
            <certificates src="user"/>
        </trust-anchors>
    </domain-config>
</network-security-config>
